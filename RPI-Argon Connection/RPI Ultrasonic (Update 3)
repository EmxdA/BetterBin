void CurrentTime()
{
    if (Time.second() != lastSecond)
    {
    int hour = Time.hour();
    int minute = Time.minute();
    int second = Time.second();
    
    Serial.print(Time.timeStr());
    
    //0 refers too the starting column of the message, and 1 represents the 2nd row
    lcd->setCursor(0,0);
    
    //We are printing time in the correct format of 00:00:00
    lcd->print(hour < 10? "   0" : "    ");
    lcd->print(hour);
    lcd->print(minute < 10? ":0": ":");
    lcd->print(minute);
    lcd->print(second < 10? ":0": ":");
    lcd->print(second);
    lastSecond = Time.second();
    }
}

void printStatus()
{
    
    leftStatus = (leftVolume/capacity)*100;
    rightStatus = (rightVolume/capacity)*100;
    
    char lStatStr[32];

    lcd->clear();
    lcd->setCursor(0,0);
    if(leftStatus  < 10 & leftStatus  > 0)
    {
        snprintf(lStatStr, sizeof(lStatStr), "Recycling  %.2f%%", leftStatus);
        lcd->print(lStatStr);
    }
    else if (leftStatus  <= 0)
    {
        lcd->print("Recycling  Empty");
    }
    else
    {
        snprintf(lStatStr, sizeof(lStatStr), "Recycling %.2f%%", leftStatus);
        lcd->print(lStatStr);
    }
    
    
    char rStatStr[32];
    lcd->setCursor(0,1);
    if(rightStatus  < 10 & rightStatus  > 0)
    {
        snprintf(rStatStr, sizeof(rStatStr), "Waste      %.2f%%", rightStatus);
        lcd->print(rStatStr);
    }
    else if (rightStatus  <= 0)
    {
        lcd->print("Waste      Empty");
    }
    else
    {
        snprintf(rStatStr, sizeof(rStatStr), "Waste     %.2f%%", rightStatus);
        lcd->print(rStatStr);
    }
    
}
